{
  "system_name": "AGI Universal Prediction System",
  "version": "1.0.0",
  
  "financial": {
    "models": ["lstm", "transformer", "rl_trader"],
    "default_accuracy": 0.85,
    "max_forecast_days": 30,
    "supported_assets": ["stocks", "forex", "crypto", "commodities"],
    "risk_management": {
      "max_position_size": 0.1,
      "stop_loss_pct": 0.05,
      "take_profit_pct": 0.1
    }
  },
  
  "medical": {
    "models": ["cnn", "rnn", "gnn"],
    "default_accuracy": 0.91,
    "supported_modalities": ["chest_xray", "ct_scan", "mri", "ehr"],
    "safety_settings": {
      "min_confidence_for_diagnosis": 0.85,
      "require_human_review": true,
      "max_processing_time": 60
    }
  },
  
  "weather": {
    "models": ["graphcast", "pangu", "metnet"],
    "default_accuracy": 0.94,
    "max_forecast_hours": 240,
    "resolution_km": 25,
    "update_frequency_minutes": 60,
    "extreme_weather_thresholds": {
      "high_temperature": 35,
      "low_temperature": 0,
      "heavy_rain_mm": 50,
      "strong_wind_kmh": 25
    }
  },
  
  "energy": {
    "models": ["lstm", "transformer", "hybrid"],
    "default_accuracy": 0.88,
    "max_forecast_hours": 168,
    "supported_types": ["electricity", "gas", "renewable"],
    "optimization": {
      "load_balancing": true,
      "renewable_priority": true,
      "cost_minimization": true
    }
  },
  
  "language": {
    "models": ["gpt", "bert", "codex"],
    "default_accuracy": 0.87,
    "max_tokens": 2048,
    "supported_languages": ["zh-TW", "zh-CN", "en", "ja"],
    "safety_filters": {
      "content_moderation": true,
      "fact_checking": false,
      "bias_detection": true
    }
  },
  
  "fusion": {
    "enabled": true,
    "min_confidence": 0.7,
    "max_domains_per_request": 5,
    "cross_domain_learning": true,
    "knowledge_graph_enabled": true
  },
  
  "performance": {
    "max_concurrent_requests": 10,
    "cache_enabled": true,
    "cache_ttl_seconds": 300,
    "request_timeout_seconds": 30,
    "retry_attempts": 3,
    "log_level": "INFO"
  },
  
  "api": {
    "host": "0.0.0.0",
    "port": 8000,
    "enable_cors": true,
    "rate_limiting": {
      "requests_per_minute": 100,
      "burst_size": 20
    },
    "authentication": {
      "enabled": false,
      "api_key_required": false
    }
  },
  
  "monitoring": {
    "metrics_enabled": true,
    "health_check_interval": 60,
    "performance_logging": true,
    "error_tracking": true,
    "alert_thresholds": {
      "error_rate_percent": 5,
      "response_time_seconds": 10,
      "memory_usage_percent": 85
    }
  },
  
  "data_sources": {
    "financial": {
      "alpha_vantage_api": "",
      "yahoo_finance": true,
      "quandl_api": ""
    },
    "weather": {
      "openweather_api": "",
      "ecmwf_access": false,
      "noaa_data": true
    },
    "medical": {
      "hl7_fhir_endpoint": "",
      "medical_databases": [],
      "privacy_compliant": true
    }
  },
  
  "security": {
    "encryption_enabled": true,
    "data_anonymization": true,
    "audit_logging": true,
    "secure_communication": true,
    "gdpr_compliant": true
  },
  
  "deployment": {
    "environment": "development",
    "auto_scaling": false,
    "load_balancer": false,
    "containerized": true,
    "cloud_provider": "none"
  }
} 