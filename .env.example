# 複製為 .env 後依本機填寫（.env 已列入 .gitignore，勿 commit 真實金鑰）
#
# 路徑（皆可用相對於「執行時工作目錄」的路徑）
# PREDICT_AI_MODELS_DIR=models
# PREDICT_AI_DATA_DIR=data
# PREDICT_AI_ARTIFACTS_ROOT=artifacts
#
# HTTP 服務載入的模型檔（launch_predict_service 亦支援 --model-path）
# UNIFIED_MODEL_PATH=models/task_stock_price_next.pkl
#
# 連接器（任務 YAML 或程式 kwargs 亦可帶入，勿寫死在程式碼）
# NEWSAPI_API_KEY=
# EIA_API_KEY=
