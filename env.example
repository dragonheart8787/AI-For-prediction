# Web server
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Plugin system
ENABLE_PLUGIN_AUTODISCOVERY=true
PLUGIN_DIR=plugins

# Database (SQLite path)
DB_PATH=comprehensive_financial_data.db

# Training config overrides (optional)
TRAIN_CONFIG=configs/train.yaml
DEVICE=auto

# Proxy (optional)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
